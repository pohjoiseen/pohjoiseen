@using Holvi.Models
@model KoTi.ViewModels.Pictures.PictureListViewModel
@{
    // In UseLinks (standalone page) mode, folder/paging navigation targets the standalone
    // Browse action with hx-push-url so the URL reflects state.  Otherwise (content editor
    // picture picker dialog) it targets the embedded List endpoint and uses the view
    // component's memcache to preserve state across dialog opens.
    string NavUrl(int? folderId, string? setSearch = null) => Model.UseLinks
        ? Url.Action("BrowseFolders", "Pictures", new { folderId, setSearch })!
        : Url.Action("List", "Pictures", new { componentId = Model.ComponentId, setId = folderId, setSearch = setSearch ?? "#", limit = Model.Limit, offset = -1 })!;

    var navTarget = Model.UseLinks ? "#browse-pictures" : "#" + Model.ComponentId;
    var navPushUrl = Model.UseLinks ? "true" : null;

    string paginatorBaseUrl;
    if (Model.UseLinks)
    {
        paginatorBaseUrl = Model.PictureSet is not null
            ? Url.Action("BrowseFolders", "Pictures", new { folderId = Model.PictureSet.Id, setSearch = Model.PictureSetSearchQuery })!
            : Url.Action("BrowseAll", "Pictures")!;
    }
    else
    {
        paginatorBaseUrl = Url.Action("List", "Pictures", new { componentId = Model.ComponentId, setId = Model.PictureSet?.Id, setSearch = Model.PictureSetSearchQuery })!;
    }
}

@if (Model.PictureSet != null)
{
     <div class="picture-set-header">
          @if (Model.PictureSet.Id == 0)
          {
               <label for="@Model.ComponentId-picture-set-search-input" style="text-wrap-mode: nowrap;" class="mr">Search for folders:</label>
               <input type="text" id="@Model.ComponentId-picture-set-search-input" class="input-block picture-set-search-input"
                      value="@Model.PictureSetSearchQuery"
                      hx-get="@NavUrl(0)" hx-target="@navTarget" hx-push-url="@navPushUrl"
                      hx-trigger="keyup changed delay:500ms"
                      hx-vals='js:{"setSearch":this.value}' />
          }
          else
          {
               <h3>
                    <button class="koti-btn" hx-get="@NavUrl(Model.PictureSet.ParentId ?? 0)"
                            hx-target="@navTarget" hx-push-url="@navPushUrl">
                         <i class="bi bi-arrow-90deg-up"></i>
                    </button>
                    @Model.PictureSet.Name
               </h3>
          }
     </div>
}

<div class="list" data-remember-state="@Model.ComponentId-set@(Model.PictureSet is not null ? Model.PictureSet.Id : "null")-offset@(Model.Offset)">
     @if (Model.PictureSet != null)
     {
          @foreach (var childSet in Model.PictureSet.Children)
          {
               @if (String.IsNullOrWhiteSpace(Model.PictureSetSearchQuery) || childSet.Name.ToLower().Contains(Model.PictureSetSearchQuery.ToLower()))
               {
                    <button class="koti-btn folder" hx-get="@NavUrl(childSet.Id)"
                            hx-target="@navTarget" hx-push-url="@navPushUrl">
                         @if (Model.ChildrenPictureSetThumbnails.ContainsKey(childSet.Id))
                         {
                              <div class="thumbnails">
                                   @foreach (var thumbnail in Model.ChildrenPictureSetThumbnails[childSet.Id])
                                   {
                                        <img src="@thumbnail" alt="" loading="lazy">
                                   }
                              </div>
                         }
                         @childSet.Name
                    </button>
               }
          }
     }

     @foreach (var picture in Model.Pictures)
     {
          <koti-picture picture-id="@picture.Id" src="@picture.DetailsUrl" title="@($"{picture.PhotographedAt?.ToString("d.MM.yyyy")}\n{picture.Filename}")"
                        height="@Picture.ThumbnailSize" width="@Math.Floor(picture.Width * 1.0 / picture.Height * Picture.ThumbnailSize)"
                        fullscreen-url="@Url.Action("Fullscreen", "Pictures", new { pictureId = picture.Id, componentId = Model.ComponentId,
                                             setId = Model.PictureSet?.Id, setSearch = Model.PictureSetSearchQuery, limit = Model.Limit, offset = Model.Offset, useLinks = Model.UseLinks ? "true" : null })"></koti-picture>
     }
</div>

<partial name="_Pagination" model="@(new PaginatorViewModel { Data = Model, HxTarget = navTarget, BaseUrl = paginatorBaseUrl, PushUrl = Model.UseLinks })" />
